# ============================================
# REQUIRED - Core Services
# ============================================

# USDA Food Database API (get from https://fdc.nal.usda.gov/api-key-signup.html)
EXPO_PUBLIC_USDA_API_KEY=your_usda_key_here

# Supabase Configuration (from your Supabase project settings)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here


# ============================================
# OPTIONAL - P2 Features
# ============================================

# Strava Integration (get from https://www.strava.com/settings/api)
EXPO_PUBLIC_STRAVA_CLIENT_ID=your_strava_client_id

# Google Maps/Places API (if using location features)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# OpenWeather API (for weather during activities)
EXPO_PUBLIC_OPENWEATHER_API_KEY=


# ============================================
# OPTIONAL - Monitoring & Analytics
# ============================================

# Sentry Crash Reporting (get from https://sentry.io)
EXPO_PUBLIC_SENTRY_DSN=

# Mixpanel Analytics (optional)
EXPO_PUBLIC_MIXPANEL_TOKEN=


# ============================================
# OPTIONAL - App Configuration
# ============================================

# App Environment (development, staging, production)
EXPO_PUBLIC_APP_ENV=development

# Feature Flags
EXPO_PUBLIC_ENABLE_STRAVA_IMPORT=true
EXPO_PUBLIC_ENABLE_SOCIAL_FEED=true
EXPO_PUBLIC_ENABLE_DM=true