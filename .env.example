# ============================================
# REQUIRED - Core Services
# ============================================

# USDA Food Database API (get from https://fdc.nal.usda.gov/api-key-signup.html)
EXPO_PUBLIC_USDA_API_KEY=your_usda_key_here

# Supabase Configuration (from your Supabase project settings)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# The "anon/public" key from Supabase dashboard — safe to embed in app bundles.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# ============================================
# OPTIONAL - Third-Party Integrations
# ============================================

# Strava Integration (optional - import workouts from Strava)
# Get from https://www.strava.com/settings/api
EXPO_PUBLIC_STRAVA_CLIENT_ID=
# WARNING: STRAVA_CLIENT_SECRET must NOT go here (never in app bundle).
#          Set it as a Supabase server secret instead:
#          supabase secrets set STRAVA_CLIENT_SECRET=your_secret_here

# Sentry Error Tracking (optional but recommended for production)
# Get from https://sentry.io/
EXPO_PUBLIC_SENTRY_DSN=