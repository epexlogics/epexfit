{
  "expo": {
    "name": "EpexFit",
    "slug": "epexfit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "epexfit",
    "owner": "epexfit",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "image": "./src/assets/splash-dark.png",
            "backgroundColor": "#0A0A0F"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow EpexFit to track your workouts."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow EpexFit to take photos and scan food barcodes.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/notification-icon.png",
          "color": "#FC4C02"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow EpexFit to access your photos to set profile picture."
        }
      ],
      "expo-asset"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.epexlogics.epexfit",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "EpexFit uses your location to track routes during activities.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "EpexFit tracks your route in the background during active workouts.",
        "NSHealthShareUsageDescription": "EpexFit reads steps and activity data from Apple Health to display your fitness stats.",
        "NSHealthUpdateUsageDescription": "EpexFit writes workout sessions to Apple Health so your activities appear in your health records.",
        "NSCameraUsageDescription": "EpexFit uses the camera for workout photo logs.",
        "NSPhotoLibraryUsageDescription": "EpexFit accesses photos for workout logs.",
        "NSMotionUsageDescription": "EpexFit uses motion sensors to count your steps automatically."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true
      }
    },
    "android": {
      "package": "com.epexlogics.epexfit",
      "minSdkVersion": 26,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
 "extra": {
    "eas": {
      "projectId": "9ebc35ef-7d5e-48bb-bdc9-4bd93a26ddb9"
    },
    "supabaseUrl": "https://yvmlnwoppiosbphfcmhe.supabase.co",
    "supabasePublishableKey": "sb_publishable_Piev8Q8GrxJBgqvPnWhmfA_nZniYBw6"
  }
  }
}